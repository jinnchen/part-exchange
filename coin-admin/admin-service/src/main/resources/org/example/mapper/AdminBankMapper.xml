<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.AdminBankMapper">

    <resultMap id="BaseResultMap" type="org.example.domain.AdminBank">
            <id property="id" column="id" />
            <result property="createBy" column="create_by" />
            <result property="modifyBy" column="modify_by" />
            <result property="created" column="created" />
            <result property="lastUpdateTime" column="last_update_time" />
            <result property="name" column="name" />
            <result property="bankName" column="bank_name" />
            <result property="bankCard" column="bank_card" />
            <result property="coinId" column="coin_id" />
            <result property="coinName" column="coin_name" />
    </resultMap>

    <sql id="Base_Column_List">
        id,create_by,modify_by,created,last_update_time,name,
        bank_name,bank_card,coin_id,coin_name
    </sql>
</mapper>
